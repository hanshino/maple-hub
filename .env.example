# 環境變數配置範例
# 複製此檔案為 .env 並填入實際值

# MapleStory API 基礎 URL (台灣版)
NEXT_PUBLIC_API_BASE_URL=https://open.api.nexon.com/maplestorytw/v1

# MapleStory API 金鑰
# 從 Nexon 開發者中心取得
API_KEY=your_nexon_api_key_here

# MySQL 資料庫
DB_HOST=infra-mysql-1
DB_PORT=3306
DB_USER=maple_hub
DB_PASSWORD=your_db_password_here
DB_NAME=maple_hub

# Redis
REDIS_HOST=infra-redis-1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password_here
